{
  "compilerOptions": {
    "target": "es2021",
    "module": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext",
    "typeRoots": ["./node_modules/@types"],
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}